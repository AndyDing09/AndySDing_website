# Warrior Desk v2 — machine secrets for the scheduled tasks.
# COPY this file to  secrets.local.ps1  (same folder) and fill in your values.
# secrets.local.ps1 is git-ignored and must never be committed.
# PAPER keys only — the system refuses live endpoints by design.

$env:ALPACA_API_KEY    = "PK_your_paper_key_here"
$env:ALPACA_SECRET_KEY = "your_paper_secret_here"

# Recommended: float data vendors. Without a float source, EVERY candidate is
# scored "float-unverified" — a ~12-point quality-score penalty that pushes even
# strong setups below the gate and locks out chop days entirely. yfinance works
# with no key (pip install yfinance); TWO agreeing sources unlock the verified
# A+ tag. Both keys below are FREE tiers — sign up and paste them in:
#   FMP:     https://site.financialmodelingprep.com/developer/docs   (free key)
#   Finnhub: https://finnhub.io/register                             (free key)
# $env:FMP_API_KEY     = "your_fmp_key_here"
# $env:FINNHUB_API_KEY = "your_finnhub_key_here"
