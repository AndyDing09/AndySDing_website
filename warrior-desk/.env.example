# Warrior Desk — secrets and the live lock. Copy to .env (which is gitignored).
# Real environment variables always override values in this file.

# Alpaca (paper keys by default — get them from the Alpaca paper dashboard).
# The agent uses the PAPER base URL unless trading_mode is live AND every lock
# in Section 0 is satisfied.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Anthropic — optional. Without it the journal still works; theses become a
# deterministic, template-based explanation instead of LLM prose.
ANTHROPIC_API_KEY=

# LIVE LOCK (Section 0). To even be considered for live trading this must equal
# exactly the magic token. Leaving it empty keeps live mode impossible.
WARRIOR_ALLOW_LIVE=

# Google Doc journal sync — optional. Without it the journal degrades to
# local-only (journal/trades.csv + journal/journal.md).
GOOGLE_CREDENTIALS_PATH=
GOOGLE_TOKEN_PATH=token.json
WARRIOR_GOOGLE_DOC_ID=
